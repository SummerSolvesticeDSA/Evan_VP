class Solution {
public:
    int square(int n) {
        int sum = 0;
        while (n > 0) {
            int d = n % 10;
            sum += d * d;
            n /= 10;
        }
        return sum;
    }

    bool isHappy(int n) {
        int slower = n;
        int faster = square(n);

        while (faster != 1 && slower != faster) {
            slower = square(slower);           
            faster = square(square(faster));

        }
        return faster==1;
    }
};
